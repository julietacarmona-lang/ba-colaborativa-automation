# Credenciales BA Colaborativa
BA_USER=20XXXXXXXXX
BA_PASSWORD=tu_password

# Google Sheets
SPREADSHEET_ID=1AbcDef...
# Nombre del tab destino. Dejalo en blanco para usar "Tickets - General"
# (el tab de producción). Para probar sin tocar datos reales, cambialo a
# "Tickets - Prueba" (o el nombre que uses para un tab de test).
SHEET_TAB=Tickets - General
# Ruta local al JSON del service account (solo para correr desde tu máquina).
# En GitHub Actions usamos GOOGLE_CREDENTIALS_JSON con el contenido del JSON.
GOOGLE_CREDENTIALS_FILE=./credentials.json
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Flags del scraper (solo dev)
HEADLESS=false
SLOW_MO=150
DOWNLOAD_DIR=./downloads
# Si KEEP_OPEN=1, al terminar queda el browser abierto para inspección manual.
KEEP_OPEN=0
# Si DEBUG_PAUSE=1, para con page.pause() antes de la descarga para inspeccionar.
DEBUG_PAUSE=0
# Reintentos antes de mandar el mail de alerta.
MAX_ATTEMPTS=3
# Nombre del filtro guardado a cargar en la bandeja antes de exportar.
# Debe coincidir exactamente con el nombre que le pusiste en "Filtros guardados"
# en la UI de BA Colaborativa. Si lo dejás vacío, el script no carga filtro
# (usa los defaults del SPA).
SAVED_FILTER_NAME=Asignados a Milton
# Carpeta donde se guarda la sesión de Chromium (cookies, localStorage).
# Así evitamos loguear cada vez (y evitamos el captcha).
USER_DATA_DIR=./.playwright-user-data
# Timeout (ms) para que resuelvas el captcha / hagas login a mano.
CAPTCHA_MANUAL_TIMEOUT_MS=300000
# Modo de login: "manual" (vos hacés login a mano la 1a vez) | "auto" (el script llena el form).
LOGIN_MODE=manual
# Canal de browser (solo aplica si BROWSER_MODE=persistent): "chrome" | "chromium".
BROWSER_CHANNEL=chrome
# Modo de conexión al browser:
#   "cdp"        — conectarse a un Chrome real corriendo en CDP_URL (recomendado
#                  en local, evita detección de automation). Requiere lanzar
#                  Chrome primero con ./scripts/chrome-cdp.sh
#   "persistent" — Playwright lanza su propio Chrome (modo CI/GitHub Actions).
BROWSER_MODE=cdp
CDP_URL=http://localhost:9222

# Mail de alerta — si falla el scraper, avisa acá.
ALERT_TO_EMAIL=julieta.carmona@educabot.com

# --- Opción A: Resend (recomendado, más simple) ---
# RESEND_API_KEY=re_xxx
# FROM_EMAIL=onboarding@resend.dev

# --- Opción B: SMTP (Gmail con app password) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_cuenta@gmail.com
# SMTP_PASSWORD=app_password_de_16_chars
# FROM_EMAIL=tu_cuenta@gmail.com

# --- Slack (opcional): URL de incoming webhook para notificar éxitos y fallos
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0.../B0.../xxxxxxx
